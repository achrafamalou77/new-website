    {
      "parameters": {
        "jsCode": "const cars = items;\nif (!cars || cars.length === 0) {\n  return { fleetText: \"No cars are currently available in our fleet.\" };\n}\n\nlet text = \"AVAILABLE CARS FOR RENTAL:\\n\";\ncars.forEach((car, index) => {\n  // Adapts seamlessly to actual database column 'daily_rate' and fallbacks to 'price_per_day'\n  const brand = car.json.brand || \"Unknown\";\n  const model = car.json.model || \"Car\";\n  const year = car.json.year || \"\";\n  const price = car.json.daily_rate || car.json.price_per_day || \"Contact us\";\n  const transmission = car.json.transmission || \"Automatic\";\n  const fuel = car.json.fuel_type || \"Petrol\";\n  \n  text += `${index + 1}. ${brand} ${model} ${year ? '(' + year + ')' : ''} - ${price} DZD/day [${transmission}, ${fuel}]\\n`;\n});\n\nreturn { fleetText: text };"
      },
      "id": "2bc8eeea-2401-4475-8123-018f97a1d555",
      "name": "Format Fleet Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3120,
        300
      ]
    },
    {
      "parameters": {
        "operation": "getAll",
        "table": "messages",
        "limit": 6,
        "filters": {
          "conditions": [
            {
              "key": "conversation_id",
              "operator": "eq",
              "value": "={{ $('Save Inbound Message').item.json[0].conversation_id }}"
            }
          ]
        },
        "additionalFields": {
          "sortBy": "created_at",
          "sortOrder": "desc"
        }
      },
      "id": "cb18290f-9012-4aef-b203-c19b20ab20aa",
      "name": "Fetch Chat History",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        2920,
        540
      ],
      "credentials": {
        "supabaseApi": {
          "id": "YOUR_SUPABASE_CREDENTIALS_ID",
          "name": "Supabase connection"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Reverse order to put messages in chronological sequence (oldest to newest)\nconst messages = [...items].reverse();\nif (messages.length === 0) {\n  return { historyText: \"No previous messages in this conversation.\" };\n}\n\nlet text = \"\";\nmessages.forEach(msg => {\n  const sender = msg.json.sender_type === 'client' ? 'Client' : 'Assistant';\n  const content = msg.json.content || \"\";\n  text += `${sender}: ${content}\\n`;\n});\n\nreturn { historyText: text };"
      },
      "id": "2bc8eeea-2401-4475-8123-018f97a1d777",
      "name": "Format History Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3120,
        540
      ]
    },
    {
      "parameters": {
        "mode": "combine",
        "combinationMode": "multiplex",
        "options": {}
      },
