      "name": "Merge Context",
      "type": "n8n-nodes-base.merge",
      "typeVersion": 2,
      "position": [
        3350,
        420
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-goog-api-key",
              "value": "YOUR_GEMINI_API_KEY_HERE"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"You are \" + ($('Query Supabase: Agency').item.json.chatbot_config?.personality?.bot_name || 'Ephedia Car Assistant') + \", the friendly and highly professional customer support representative for \" + $('Query Supabase: Agency').item.json.company_name + \" (a premier car rental SaaS platform based in Algeria).\\n\\nYOUR RULES AND INSTRUCTIONS:\\n1. Greeting: \" + ($('Query Supabase: Agency').item.json.chatbot_config?.personality?.bot_greeting || 'Hello and welcome!') + \"\\n2. Languages: Speak in Algerian Darja (Arabic dialect), French, or standard Arabic/English. Respond matching the language used by the user in their message. Ensure the tone is warm, professional, and locally engaging.\\n3. Prices: Strictly quote rental prices in Algerian Dinars (DZD) using a clean local format, e.g., '5,000 DZD/day'.\\n4. Length: Keep your responses highly concise, polite, and spaced out with simple emojis. Ideal for standard WhatsApp screen sizes. Never output excessively long text paragraphs.\\n5. Actions: Guide them to select one of the available cars, offer to book, and ask them for rental dates or details politely.\\n\\nCONTEXT INFO (AVAILABLE FLEET INVENTORY):\\n\" + $json.fleetText + \"\\n\\nCONVERSATION HISTORY:\\n\" + $('Format History Text').item.json.historyText + \"\\n\\nNEW USER MESSAGE:\\nClient: \" + $('Parse WhatsApp Message').item.json.messageText + \"\\n\\nAssistant Reply:\"\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"temperature\": 0.7,\n    \"maxOutputTokens\": 500\n  }\n}"
      },
      "id": "e0b73339-ff74-4b53-90d5-bf6774e1d444",
      "name": "Call Gemini API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        3540,
        420
      ]
    },
    {
      "parameters": {
        "jsCode": "const response = item.json;\nlet reply = \"\";\ntry {\n  reply = response.candidates[0].content.parts[0].text;\n} catch (e) {\n  reply = \"Désolé, nous rencontrons un petit incident technique. Veuillez nous excuser et réessayer dans un instant, ou contactez un conseiller.\";\n}\nreturn {\n  replyText: reply.trim()\n};"
      },
      "id": "2bc8eeea-2401-4475-8123-018f97a1d999",
      "name": "Parse Gemini Reply",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        3740,
        420
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=\"https://graph.facebook.com/v20.0/\" + $('Parse WhatsApp Message').item.json.phoneId + \"/messages\"",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_META_WHATSAPP_TOKEN_HERE"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"recipient_type\": \"individual\",\n  \"to\": \"={{ $('Parse WhatsApp Message').item.json.clientPhoneRaw }}\",\n  \"type\": \"text\",\n  \"text\": {\n    \"body\": \"={{ $json.replyText }}\"\n  }\n}"
      },
      "id": "e0b73339-ff74-4b53-90d5-bf6774e1d555",
      "name": "Send WhatsApp Reply",
