    {
      "parameters": {
        "jsCode": "const body = item.json.body;\nconst value = body.entry[0].changes[0].value;\nconst message = value.messages[0];\nconst contact = value.contacts ? value.contacts[0] : null;\n\n// Normalize phone numbers for easy querying in Supabase\nconst clientPhoneRaw = message.from; // raw WA phone (e.g. \"213555123456\")\nconst clientPhoneNormalized = '+' + clientPhoneRaw; // formatted standard (\"+213555123456\")\nconst businessPhone = value.metadata.display_phone_number; // display phone of agency\nconst phoneId = value.metadata.phone_number_id; // meta platform ID of phone\n\nreturn {\n  clientPhoneRaw,\n  clientPhoneNormalized,\n  clientName: contact ? contact.profile.name : \"Client WhatsApp\",\n  messageText: message.text ? message.text.body : \"\",\n  messageId: message.id,\n  timestamp: message.timestamp,\n  businessPhone,\n  phoneId\n};\n"
      },
